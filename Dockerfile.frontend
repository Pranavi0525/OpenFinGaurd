FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    streamlit==1.54.0 \
    plotly==6.5.2 \
    requests==2.32.5 \
    pandas>=2.2.0

COPY frontend/ ./frontend/
COPY reports/ ./reports/

EXPOSE 8501

CMD ["streamlit", "run", "frontend/app.py", \
     "--server.port", "8501", \
     "--server.address", "0.0.0.0", \
     "--server.headless", "true"]